{
  "name": "elkaza-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "dev": "next dev -p 3002",
    "build": "next build && node scripts/postprocess-static-export.mjs",
    "start": "node scripts/serve-static-export.mjs out 3002",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "dev:3002": "next dev -p 3002",
    "start:3002": "node scripts/serve-static-export.mjs out 3002",
    "analyze": "ANALYZE=true next build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "a11y-audit": "node scripts/a11y-audit.js"
  },
  "dependencies": {
    "lucide-react": "^0.552.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.10.38",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "git add"
    ]
  },
  "optionalDependencies": {
    "@next/swc-win32-x64-msvc": "^16.2.9"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
